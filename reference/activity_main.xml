<?xml version="1.0" encoding="utf-8"?>
<!--
  Place MeshGradientView as the first child so it sits behind everything else.
  The FrameLayout lets your real UI stack on top without extra nesting cost.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ── Layer 0 : animated mesh gradient background ── -->
    <com.example.meshgradient.MeshGradientView
        android:id="@+id/meshGradient"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- ── Layer 1 : your real content goes here ── -->
    <!--
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        …
    </androidx.constraintlayout.widget.ConstraintLayout>
    -->

</FrameLayout>
